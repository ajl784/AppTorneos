-- =====================================================
-- AppTorneos - Esquema PostgreSQL
-- =====================================================

-- Opcional: crear base de datos desde postgres
-- CREATE DATABASE app_torneos;
-- \c app_torneos

CREATE EXTENSION IF NOT EXISTS pgcrypto;

-- =====================================================
-- Catálogos
-- =====================================================

CREATE TABLE tipo_torneo (
	id_tipo_torneo BIGSERIAL PRIMARY KEY,
	nombre VARCHAR(80) NOT NULL UNIQUE,
	descripcion TEXT
);

CREATE TABLE categoria (
	id_categoria BIGSERIAL PRIMARY KEY,
	nombre VARCHAR(80) NOT NULL UNIQUE,
	participantes_por_partida INTEGER NOT NULL CHECK (participantes_por_partida > 0),
	norma TEXT,
	descripcion TEXT
);

-- =====================================================
-- Identidad y perfiles
-- =====================================================

CREATE TABLE usuario (
	id_usuario BIGSERIAL PRIMARY KEY,
	correo VARCHAR(255) NOT NULL UNIQUE,
	nombre_usuario VARCHAR(120) NOT NULL,
	password_hash TEXT NOT NULL
);

CREATE TABLE organizador (
	id_organizador BIGSERIAL PRIMARY KEY,
	id_usuario BIGINT NOT NULL UNIQUE REFERENCES usuario(id_usuario) ON DELETE CASCADE
);

CREATE TABLE arbitro_torneo (
	id_arbitro_torneo BIGSERIAL PRIMARY KEY,
	id_usuario BIGINT NOT NULL UNIQUE REFERENCES usuario(id_usuario) ON DELETE CASCADE
);

CREATE TABLE jugador_individual (
	id_jugador BIGSERIAL PRIMARY KEY,
	id_usuario BIGINT NOT NULL UNIQUE REFERENCES usuario(id_usuario) ON DELETE CASCADE,
	elo INTEGER NOT NULL DEFAULT 1200 CHECK (elo >= 0)
);

CREATE TABLE equipo (
	id_equipo BIGSERIAL PRIMARY KEY,
	nombre VARCHAR(120) NOT NULL UNIQUE,
	descripcion TEXT,
	elo INTEGER NOT NULL DEFAULT 1200 CHECK (elo >= 0)
);

CREATE TABLE entrenador_equipo (
	id_entrenador BIGSERIAL PRIMARY KEY,
	id_usuario BIGINT NOT NULL REFERENCES usuario(id_usuario) ON DELETE CASCADE,
	id_equipo BIGINT NOT NULL REFERENCES equipo(id_equipo) ON DELETE CASCADE,
	fecha_inicio DATE NOT NULL,
	fecha_fin DATE,
	CHECK (fecha_fin IS NULL OR fecha_fin >= fecha_inicio)
);

-- =====================================================
-- Núcleo de torneos
-- =====================================================

CREATE TABLE torneo (
	id_torneo BIGSERIAL PRIMARY KEY,
	nombre VARCHAR(140) NOT NULL,
	descripcion TEXT,
	id_categoria BIGINT NOT NULL REFERENCES categoria(id_categoria),
	id_tipo_torneo BIGINT NOT NULL REFERENCES tipo_torneo(id_tipo_torneo),
	id_organizador BIGINT REFERENCES organizador(id_organizador),
	UNIQUE (nombre, id_categoria, id_tipo_torneo)
);

CREATE TABLE participacion_torneo_individual (
	id_participacion_individual BIGSERIAL PRIMARY KEY,
	id_torneo BIGINT NOT NULL REFERENCES torneo(id_torneo) ON DELETE CASCADE,
	id_jugador BIGINT NOT NULL REFERENCES jugador_individual(id_jugador) ON DELETE CASCADE,
	fecha TIMESTAMPTZ NOT NULL DEFAULT NOW(),
	respuesta JSONB,
	estado VARCHAR(30) NOT NULL DEFAULT 'inscrito',
	CHECK (estado IN ('inscrito', 'rechazado', 'aprobado')),
	puntuacion NUMERIC(8,2) NOT NULL DEFAULT 0,
	UNIQUE (id_torneo, id_jugador)
);

CREATE TABLE participacion_torneo_equipo (
	id_participacion_equipo BIGSERIAL PRIMARY KEY,
	id_torneo BIGINT NOT NULL REFERENCES torneo(id_torneo) ON DELETE CASCADE,
	id_equipo BIGINT NOT NULL REFERENCES equipo(id_equipo) ON DELETE CASCADE,
	fecha TIMESTAMPTZ NOT NULL DEFAULT NOW(),
	respuesta JSONB,
	estado VARCHAR(30) NOT NULL DEFAULT 'inscrito',
	CHECK (estado IN ('inscrito', 'rechazado', 'aprobado')),
	puntuacion NUMERIC(8,2) NOT NULL DEFAULT 0,
	UNIQUE (id_torneo, id_equipo)
);

CREATE TABLE encuesta (
	id_encuesta BIGSERIAL PRIMARY KEY,
	id_organizador BIGINT REFERENCES organizador(id_organizador) ON DELETE SET NULL,
	id_torneo BIGINT REFERENCES torneo(id_torneo) ON DELETE CASCADE,
	fecha TIMESTAMPTZ NOT NULL DEFAULT NOW(),
	configuracion JSONB NOT NULL
);

-- =====================================================
-- Partidos, convocatoria y arbitraje
-- =====================================================

CREATE TABLE partido (
	id_partido BIGSERIAL PRIMARY KEY,
	id_torneo BIGINT NOT NULL REFERENCES torneo(id_torneo) ON DELETE CASCADE,
	fecha_hora TIMESTAMPTZ NOT NULL,
	lugar VARCHAR(180),
	estado VARCHAR(20) NOT NULL DEFAULT 'planificado',
	CHECK (estado IN ('planificado', 'en_curso', 'acabado', 'cancelado'))
);

CREATE TABLE arbitro_partido (
	id_arbitro_partido BIGSERIAL PRIMARY KEY,
	id_partido BIGINT NOT NULL REFERENCES partido(id_partido) ON DELETE CASCADE,
	id_arbitro_torneo BIGINT NOT NULL REFERENCES arbitro_torneo(id_arbitro_torneo),
	acta JSONB,
	UNIQUE (id_partido, id_arbitro_torneo)
);

CREATE TABLE participacion_partido (
	id_participacion_partido BIGSERIAL PRIMARY KEY,
	id_partido BIGINT NOT NULL REFERENCES partido(id_partido) ON DELETE CASCADE,
	id_participacion_individual BIGINT REFERENCES participacion_torneo_individual(id_participacion_individual) ON DELETE CASCADE,
	id_participacion_equipo BIGINT REFERENCES participacion_torneo_equipo(id_participacion_equipo) ON DELETE CASCADE,
	punto INTEGER NOT NULL DEFAULT 0,
	CHECK (
		(
			id_participacion_individual IS NOT NULL
			AND id_participacion_equipo IS NULL
		)
		OR
		(
			id_participacion_individual IS NULL
			AND id_participacion_equipo IS NOT NULL
		)
	)
);

CREATE TABLE convocatoria (
	id_convocatoria BIGSERIAL PRIMARY KEY,
	id_participacion_partido BIGINT NOT NULL REFERENCES participacion_partido(id_participacion_partido) ON DELETE CASCADE,
	creado_en TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE TABLE jugador_convocatoria (
	id_jugador_convocatoria BIGSERIAL PRIMARY KEY,
	id_convocatoria BIGINT NOT NULL REFERENCES convocatoria(id_convocatoria) ON DELETE CASCADE,
	id_jugador BIGINT NOT NULL REFERENCES jugador_individual(id_jugador) ON DELETE CASCADE,
	UNIQUE (id_convocatoria, id_jugador)
);

-- =====================================================
-- Índices útiles
-- =====================================================

CREATE INDEX idx_torneo_categoria ON torneo(id_categoria);
CREATE INDEX idx_torneo_tipo ON torneo(id_tipo_torneo);
CREATE INDEX idx_partido_torneo ON partido(id_torneo);
CREATE INDEX idx_pp_partido ON participacion_partido(id_partido);
CREATE INDEX idx_pp_individual ON participacion_partido(id_participacion_individual);
CREATE INDEX idx_pp_equipo ON participacion_partido(id_participacion_equipo);
CREATE INDEX idx_pte_torneo ON participacion_torneo_equipo(id_torneo);
CREATE INDEX idx_pti_torneo ON participacion_torneo_individual(id_torneo);

