-- =====================================================
-- AppTorneos - Esquema PostgreSQL (modelo modificado)
-- =====================================================

-- Opcional: crear base de datos desde postgres
-- CREATE DATABASE app_torneos;
-- \c app_torneos

CREATE EXTENSION IF NOT EXISTS pgcrypto;

-- =====================================================
-- Catálogos
-- =====================================================

CREATE TABLE tipo_torneo (
	id_tipo_torneo BIGSERIAL PRIMARY KEY,
	nombre VARCHAR(80) NOT NULL UNIQUE,
	descripcion TEXT
);

CREATE TABLE categoria (
	id_categoria BIGSERIAL PRIMARY KEY,
	nombre VARCHAR(80) NOT NULL UNIQUE,
	participantes_por_partida INTEGER NOT NULL CHECK (participantes_por_partida > 0),
	norma TEXT,
	descripcion TEXT
);

-- Restricción opcional de disponibilidad entre categoría y tipo de torneo.
CREATE TABLE categoria_tipo_torneo (
	id_categoria_tipo_torneo BIGSERIAL PRIMARY KEY,
	id_categoria BIGINT NOT NULL REFERENCES categoria(id_categoria) ON DELETE CASCADE,
	id_tipo_torneo BIGINT NOT NULL REFERENCES tipo_torneo(id_tipo_torneo) ON DELETE CASCADE,
	UNIQUE (id_categoria, id_tipo_torneo)
);

-- =====================================================
-- Identidad y roles
-- =====================================================

CREATE TABLE usuario (
	id_usuario BIGSERIAL PRIMARY KEY,
	correo VARCHAR(255) NOT NULL UNIQUE,
	nombre_usuario VARCHAR(120) NOT NULL,
	password_hash TEXT NOT NULL,
	nombre VARCHAR(120) NOT NULL DEFAULT '',
	apellidos VARCHAR(120),
	fotoperfil TEXT,
	fechanacimiento DATE,
	genero VARCHAR(20)
);

CREATE TABLE equipo (
	id_equipo BIGSERIAL PRIMARY KEY,
	nombre VARCHAR(120) NOT NULL UNIQUE,
	descripcion TEXT,
	elo INTEGER NOT NULL DEFAULT 1200 CHECK (elo >= 0),
	id_categoria BIGINT NOT NULL REFERENCES categoria(id_categoria)
);

CREATE TABLE pertenece (
	id_pertenece BIGSERIAL PRIMARY KEY,
	id_usuario BIGINT NOT NULL REFERENCES usuario(id_usuario) ON DELETE CASCADE,
	id_equipo BIGINT NOT NULL REFERENCES equipo(id_equipo) ON DELETE CASCADE,
	fecha_inicio DATE NOT NULL,
	fecha_fin DATE,
	CHECK (fecha_fin IS NULL OR fecha_fin >= fecha_inicio),
	UNIQUE (id_usuario, id_equipo, fecha_inicio)
);

CREATE TABLE entrenador_equipo (
	id_entrenador BIGSERIAL PRIMARY KEY,
	id_usuario BIGINT NOT NULL REFERENCES usuario(id_usuario) ON DELETE CASCADE,
	id_equipo BIGINT NOT NULL REFERENCES equipo(id_equipo) ON DELETE CASCADE,
	fecha_inicio DATE NOT NULL,
	fecha_fin DATE,
	CHECK (fecha_fin IS NULL OR fecha_fin >= fecha_inicio),
	UNIQUE (id_usuario, id_equipo, fecha_inicio)
);

CREATE TABLE solicitud_equipo (
	id_solicitud_equipo BIGSERIAL PRIMARY KEY,
	id_equipo BIGINT NOT NULL REFERENCES equipo(id_equipo) ON DELETE CASCADE,
	id_usuario BIGINT NOT NULL REFERENCES usuario(id_usuario) ON DELETE CASCADE,
	fecha TIMESTAMPTZ NOT NULL DEFAULT NOW(),
	respuesta JSONB,
	estado VARCHAR(20) NOT NULL DEFAULT 'pendiente',
	id_entrenador_decisor BIGINT REFERENCES usuario(id_usuario) ON DELETE SET NULL,
	fecha_decision TIMESTAMPTZ,
	CHECK (estado IN ('pendiente', 'aceptada', 'rechazada'))
);

CREATE UNIQUE INDEX uq_solicitud_equipo_pendiente
ON solicitud_equipo (id_equipo, id_usuario)
WHERE estado = 'pendiente';

CREATE TABLE arbitro_torneo (
	id_arbitro_torneo BIGSERIAL PRIMARY KEY,
	id_usuario BIGINT NOT NULL REFERENCES usuario(id_usuario) ON DELETE CASCADE,
	id_torneo BIGINT NOT NULL,
	UNIQUE (id_usuario, id_torneo)
);

-- =====================================================
-- Núcleo de torneos
-- =====================================================

CREATE TABLE torneo (
	id_torneo BIGSERIAL PRIMARY KEY,
	nombre VARCHAR(140) NOT NULL,
	descripcion TEXT,
	fecha_inicio TIMESTAMPTZ,
	fecha_fin TIMESTAMPTZ,
	estado VARCHAR(20) NOT NULL DEFAULT 'inscripcion_abierta',
	limite_equipos INTEGER CHECK (limite_equipos IS NULL OR limite_equipos > 0),
	
	id_categoria BIGINT NOT NULL,
	id_tipo_torneo BIGINT NOT NULL,
	id_organizador BIGINT REFERENCES usuario(id_usuario) ON DELETE SET NULL,
	encuesta JSONB,
	norma_puntuacion TEXT,
	preferencia_horario JSONB,
	CHECK (estado IN ('inscripcion_abierta', 'inscripcion_cerrada', 'inscripcion_terminada', 'en_curso', 'acabado', 'cancelado')),
	
	CHECK (fecha_fin IS NULL OR fecha_inicio IS NULL OR fecha_fin >= fecha_inicio),
	UNIQUE (nombre, id_categoria, id_tipo_torneo),
	FOREIGN KEY (id_categoria) REFERENCES categoria(id_categoria),
	FOREIGN KEY (id_tipo_torneo) REFERENCES tipo_torneo(id_tipo_torneo),
	FOREIGN KEY (id_categoria, id_tipo_torneo)
		REFERENCES categoria_tipo_torneo(id_categoria, id_tipo_torneo)
);

ALTER TABLE arbitro_torneo
	ADD CONSTRAINT arbitro_torneo_id_torneo_fkey
	FOREIGN KEY (id_torneo) REFERENCES torneo(id_torneo) ON DELETE CASCADE;

CREATE TABLE participacion_torneo_equipo (
	id_participacion_equipo BIGSERIAL PRIMARY KEY,
	id_torneo BIGINT NOT NULL REFERENCES torneo(id_torneo) ON DELETE CASCADE,
	id_equipo BIGINT NOT NULL REFERENCES equipo(id_equipo) ON DELETE CASCADE,
	fecha TIMESTAMPTZ NOT NULL DEFAULT NOW(),
	respuesta JSONB,
	estado VARCHAR(30) NOT NULL DEFAULT 'pendiente',
	puntuacion NUMERIC(8,2) NOT NULL DEFAULT 0,
	CHECK (estado IN ('jugando', 'suspendido', 'pendiente', 'eliminado')),
	UNIQUE (id_torneo, id_equipo)
);

CREATE TABLE partido (
	id_partido BIGSERIAL PRIMARY KEY,
	id_torneo BIGINT NOT NULL REFERENCES torneo(id_torneo) ON DELETE CASCADE,
	fecha_hora TIMESTAMPTZ NOT NULL,
	lugar VARCHAR(180),
	estado VARCHAR(20) NOT NULL DEFAULT 'planificado',
	jornada INTEGER,
	ronda INTEGER,
	orden_ronda INTEGER,
	id_partido_siguiente BIGINT REFERENCES partido(id_partido) ON DELETE SET NULL,
	ganador_id_participacion_equipo BIGINT REFERENCES participacion_torneo_equipo(id_participacion_equipo) ON DELETE SET NULL,
	CHECK (estado IN ('planificado', 'en_curso', 'acabado', 'cancelado')),
	CHECK (jornada IS NULL OR jornada > 0),
	CHECK (ronda IS NULL OR ronda > 0),
	CHECK (orden_ronda IS NULL OR orden_ronda > 0)
);

-- Evita duplicados en bracket (solo cuando hay ronda)
CREATE UNIQUE INDEX uq_partido_torneo_ronda_orden
ON partido (id_torneo, ronda, orden_ronda)
WHERE ronda IS NOT NULL AND orden_ronda IS NOT NULL;

CREATE TABLE participacion_partido (
	id_participacion_partido BIGSERIAL PRIMARY KEY,
	id_partido BIGINT NOT NULL REFERENCES partido(id_partido) ON DELETE CASCADE,
	id_participacion_equipo BIGINT NOT NULL REFERENCES participacion_torneo_equipo(id_participacion_equipo) ON DELETE CASCADE,
	punto INTEGER NOT NULL DEFAULT 0,
	UNIQUE (id_partido, id_participacion_equipo)
);

CREATE TABLE arbitro_partido (
	id_arbitro_partido BIGSERIAL PRIMARY KEY,
	id_partido BIGINT NOT NULL REFERENCES partido(id_partido) ON DELETE CASCADE,
	id_arbitro_torneo BIGINT NOT NULL REFERENCES arbitro_torneo(id_arbitro_torneo),
	acta JSONB,
	UNIQUE (id_partido, id_arbitro_torneo)
);

CREATE TABLE historial_elo (
	id_historial_elo BIGSERIAL PRIMARY KEY,
	id_equipo BIGINT NOT NULL REFERENCES equipo(id_equipo) ON DELETE CASCADE,
	elo_anterior INTEGER NOT NULL CHECK (elo_anterior >= 0),
	elo_nuevo INTEGER NOT NULL CHECK (elo_nuevo >= 0),
	descripcion TEXT,
	creado_en TIMESTAMPTZ NOT NULL DEFAULT NOW()
);


